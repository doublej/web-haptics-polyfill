{
  "name": "web-haptics-polyfill",
  "version": "0.1.0",
  "description": "Cross-platform haptic feedback for mobile web — iOS Safari exploit + Android vibrate + PWM intensity",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.mjs",
      "require": "./dist/svelte/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "svelte": "^5.0.0",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "svelte": ">=5",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "svelte": { "optional": true },
    "vue": { "optional": true }
  },
  "license": "MIT"
}
